# Copy this file to .secrets and fill in the values for integration testing
# Run with: act --secret-file .secrets

AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_SESSION_TOKEN is required when using temporary credentials (e.g. from OIDC or STS assume-role)
AWS_SESSION_TOKEN=your-session-token
AWS_REGION=us-east-1
STACK_NAME=your-stack-name